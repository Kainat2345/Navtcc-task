import pandas as pd

print("=== PANDAS DATAFRAME EXAMPLE ===\n")

# Create a simple dataset with columns "calories" and "duration"
data = {
    "calories": [420, 380, 390],
    "duration": [50, 40, 45]
}

# Load data into a DataFrame object
df = pd.DataFrame(data)
print("DataFrame:\n", df)
print()

# Locate and print row with index 0
print("Row at index 0:")
print(df.loc[0])
print()

# Locate and print row with index 0 and 1
print("Rows at index 0 and 1:")
print(df.loc[[0, 1]])
print()

# Create a DataFrame with custom index labels
df_named = pd.DataFrame(data, index=["day1", "day2", "day3"])
print("DataFrame with named indexes:\n", df_named)
print()

# Locate and print row with named index "day2"
print("Row with named index 'day2':")
print(df_named.loc["day2"])
import numpy as np

arr = np.array([10, 20, 30, 40, 50])

print("Iterating 1D array:")
for x in arr:
    print(x)
    arr2d = np.array([[1, 2, 3],
                  [4, 5, 6]])

print("\nIterating 2D array (row-wise):")
for row in arr2d:
    print(row)

print("\nIterating each element in 2D array:")
for row in arr2d:
    for elem in row:
        print(elem)
    
print("\nIterating with arr2d.flat (1D iterator):")
for elem in arr2d.flat:
    print(elem)

print("\nIterating using np.nditer:")
for elem in np.nditer(arr2d):
    print(elem)

print("\nIterating with index using np.ndenumerate:")
for index, value in np.ndenumerate(arr2d):
    print(f"Index {index} -> Value {value}")